{
  "name": "openrouter-agent",
  "displayName": "OpenRouter Agent — AI Coding Assistant",
  "description": "Free AI coding assistant for VS Code — use Claude, GPT-4, Gemini & 300+ models. Ask, Plan, and Agent modes. No subscription required.",
  "version": "1.22.10",
  "publisher": "ZihadHosan",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZihadHosan/openrouter-agent.git"
  },
  "bugs": {
    "url": "https://github.com/ZihadHosan/openrouter-agent/issues"
  },
  "homepage": "https://github.com/ZihadHosan/openrouter-agent#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "AI",
    "Chat"
  ],
  "keywords": [
    "ai",
    "copilot",
    "claude",
    "chatgpt",
    "gemini",
    "openrouter",
    "agent",
    "coding-assistant",
    "llm",
    "free"
  ],
  "galleryBanner": {
    "color": "#0a1628",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:openrouterAgent.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openrouterAgent.openChat",
        "title": "OpenRouter: Open Chat",
        "shortTitle": "Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "openrouterAgent.askCurrentFile",
        "title": "OpenRouter: Ask About Current File"
      },
      {
        "command": "openrouterAgent.explainSelection",
        "title": "OpenRouter: Explain Selection"
      },
      {
        "command": "openrouterAgent.fixSelection",
        "title": "OpenRouter: Fix Selection"
      },
      {
        "command": "openrouterAgent.setPermissions",
        "title": "OpenRouter: Agent Permissions"
      },
      {
        "command": "openrouterAgent.setApiKey",
        "title": "OpenRouter: Set API Key"
      },
      {
        "command": "openrouterAgent.clearApiKey",
        "title": "OpenRouter: Clear API Key"
      }
    ],
    "keybindings": [
      {
        "command": "openrouterAgent.openChat",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "openrouterAgent.openChat",
          "group": "navigation@100",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "OpenRouter Agent",
      "properties": {
        "openrouterAgent.agentPermissions": {
          "type": "string",
          "enum": [
            "ask",
            "readOnly",
            "workspace",
            "full"
          ],
          "enumDescriptions": [
            "Ask before file writes and terminal commands.",
            "Auto-approve list/read files only.",
            "Auto-approve reads and file writes; ask before terminal commands.",
            "Auto-approve reads, writes, and safe commands. Destructive commands always ask."
          ],
          "default": "ask",
          "markdownDescription": "Control when the agent runs tools without asking. Change quickly via **OpenRouter: Agent Permissions** in the Command Palette.\n\n**API key:** Command Palette → `OpenRouter: Set API Key` (secure storage, not settings.json). **Models:** use the chat model menu (catalog + pool toggles), not Settings.",
          "order": 1
        },
        "openrouterAgent.shell": {
          "type": "string",
          "default": "",
          "markdownDescription": "Primary shell for in-chat commands. **Leave empty** to use VS Code default + built-in fallbacks (PowerShell, Git Bash, cmd, WSL on Windows; bash/zsh/sh on macOS/Linux).",
          "order": 2
        },
        "openrouterAgent.shellFallbacks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra shell paths tried after the default chain. Example: `C:\\\\Program Files\\\\Git\\\\bin\\\\bash.exe`",
          "order": 3
        },
        "openrouterAgent.chatFontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 24,
          "markdownDescription": "Chat message font size in pixels. **0** uses 14px (readable default for chat prose).",
          "order": 4
        },
        "openrouterAgent.streamResponses": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Stream assistant replies token-by-token in chat. Disable for slower machines or if you prefer instant full messages.",
          "order": 5
        },
        "openrouterAgent.contextGatherTimeoutMs": {
          "type": "number",
          "default": 1500,
          "minimum": 500,
          "maximum": 10000,
          "markdownDescription": "Max milliseconds to wait for editor/workspace context before sending the request.",
          "order": 6
        },
        "openrouterAgent.debugPerformance": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Log timing to the **Developer Console** (`[perf]` lines for context gather, API, etc.). Or set environment variable `DEBUG_PERF=1`.",
          "order": 7
        },
        "openrouterAgent.showModelPricing": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show selected model per-million token pricing in the chat composer (from OpenRouter catalog).",
          "order": 8
        },
        "openrouterAgent.showAccountBalance": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show OpenRouter credit balance in the top-right of the chat composer when the API returns it (account credits or per-key limit).",
          "order": 8.25
        },
        "openrouterAgent.maxAttachments": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "markdownDescription": "Maximum files or images attached to a single message.",
          "order": 9
        },
        "openrouterAgent.maxImageSizeMb": {
          "type": "number",
          "default": 4,
          "minimum": 1,
          "maximum": 20,
          "markdownDescription": "Maximum size per image attachment (MB).",
          "order": 10
        },
        "openrouterAgent.maxPdfSizeMb": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 50,
          "markdownDescription": "Maximum size per PDF attachment (MB).",
          "order": 11
        }
      }
    }
  },
  "scripts": {
    "precompile": "node scripts/bump-version-on-change.mjs",
    "build:hljs": "esbuild scripts/hljs-entry.mjs --bundle --minify --format=iife --global-name=hljs --footer:js=\"if(typeof hljs!=='undefined'&&hljs.hljs)hljs=hljs.hljs;\" --outfile=media/highlight.min.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test:sanitize": "npm run compile && node scripts/test-tool-sanitize.mjs",
    "version:sync": "node scripts/bump-version-on-change.mjs",
    "package:vsix": "npm run compile && npx @vscode/vsce package --allow-missing-repository",
    "publish:marketplace": "npm run package:vsix && npx @vscode/vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "highlight.js": "^11.11.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "marked": "^18.0.4"
  }
}
