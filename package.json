{
  "name": "openrouter-agent",
  "displayName": "OpenRouter Agent",
  "description": "Lightweight AI chat for VS Code and Cursor — Ask, Plan, and Agent modes powered by OpenRouter.",
  "version": "1.0.0",
  "publisher": "ZihadHosan",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZihadHosan/openrouter-agent.git"
  },
  "bugs": {
    "url": "https://github.com/ZihadHosan/openrouter-agent/issues"
  },
  "homepage": "https://github.com/ZihadHosan/openrouter-agent#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "openrouter",
    "ai",
    "chat",
    "agent",
    "llm",
    "assistant",
    "copilot"
  ],
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:openrouterAgent.openChat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openrouterAgent.openChat",
        "title": "OpenRouter: Open Chat",
        "shortTitle": "Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "openrouterAgent.askCurrentFile",
        "title": "OpenRouter: Ask About Current File"
      },
      {
        "command": "openrouterAgent.explainSelection",
        "title": "OpenRouter: Explain Selection"
      },
      {
        "command": "openrouterAgent.fixSelection",
        "title": "OpenRouter: Fix Selection"
      },
      {
        "command": "openrouterAgent.setPermissions",
        "title": "OpenRouter: Agent Permissions"
      },
      {
        "command": "openrouterAgent.setApiKey",
        "title": "OpenRouter: Set API Key"
      },
      {
        "command": "openrouterAgent.clearApiKey",
        "title": "OpenRouter: Clear API Key"
      }
    ],
    "keybindings": [
      {
        "command": "openrouterAgent.openChat",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "openrouterAgent.openChat",
          "group": "navigation@100",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "OpenRouter Agent",
      "properties": {
        "openrouterAgent.models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "z-ai/glm-4.5-air:free",
            "openrouter/owl-alpha",
            "deepseek/deepseek-v4-flash"
          ],
          "markdownDescription": "Fallback models (max 3) when **Auto** is selected in chat.\n\n**API key:** not stored here — use Command Palette → `OpenRouter: Set API Key` (masked, secure storage).",
          "maxItems": 3,
          "order": 1
        },
        "openrouterAgent.agentPermissions": {
          "type": "string",
          "enum": [
            "ask",
            "readOnly",
            "workspace",
            "full"
          ],
          "enumDescriptions": [
            "Ask before file writes and terminal commands.",
            "Auto-approve list/read files only.",
            "Auto-approve reads and file writes; ask before terminal commands.",
            "Auto-approve reads, writes, and safe commands. Destructive commands always ask."
          ],
          "default": "ask",
          "markdownDescription": "Control when the agent runs tools without asking. Change quickly via **OpenRouter: Agent Permissions** in the Command Palette.",
          "order": 2
        },
        "openrouterAgent.shell": {
          "type": "string",
          "default": "",
          "markdownDescription": "Primary shell for in-chat commands. **Leave empty** to use VS Code default + built-in fallbacks (PowerShell, Git Bash, cmd, WSL on Windows; bash/zsh/sh on macOS/Linux).",
          "order": 3
        },
        "openrouterAgent.shellFallbacks": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "markdownDescription": "Extra shell paths tried after the default chain. Example: `C:\\\\Program Files\\\\Git\\\\bin\\\\bash.exe`",
          "order": 4
        },
        "openrouterAgent.chatFontSize": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 24,
          "markdownDescription": "Chat message font size in pixels. **0** uses 14px (readable default for chat prose).",
          "order": 5
        },
        "openrouterAgent.streamResponses": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Stream assistant replies token-by-token in chat. Disable for slower machines or if you prefer instant full messages.",
          "order": 6
        }
      }
    }
  },
  "scripts": {
    "precompile": "node scripts/bump-version-on-change.mjs",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "version:sync": "node scripts/bump-version-on-change.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "marked": "^18.0.4"
  }
}
