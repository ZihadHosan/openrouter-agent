{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run OpenRouter Agent",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/openrouter-agent"
      ],
      "outFiles": [
        "${workspaceFolder}/openrouter-agent/dist/**/*.js"
      ],
      "preLaunchTask": "compile-openrouter-agent"
    }
  ]
}
